{
  "name": "@samples/atomic-search-commerce-react",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:assets": "node utils/ci/copy-files.mjs packages/atomic-react/dist/assets public/assets packages/atomic-react/dist/lang public/lang packages/atomic/dist/themes public/themes",
    "dev": "pnpm dev:vite",
    "dev:vite": "vite",
    "build": "pnpm build:ts && pnpm build:vite",
    "build:ts": "pnpm --filter @coveo/ci if-not-cdn -- \"tsc -b\"",
    "build:vite": "pnpm --filter @coveo/ci if-not-cdn -- \"vite build\""
  },
  "dependencies": {
    "@coveo/atomic-react": "^3.11.20",
    "@coveo/headless": "^3.50.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "7.15.0"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "typescript": "6.0.3",
    "vite": "8.0.10"
  }
}
